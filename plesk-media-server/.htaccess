# POI•LOVE — media.poilove.com
# Cultural Bridge OS · MIT License

Options -Indexes
ErrorDocument 403 /403.html
ErrorDocument 404 /403.html

# --- Blocca accesso diretto a config e helpers ---
<FilesMatch "(^config\.php$)">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Passa l'header Authorization al PHP: con PHP 8.3 via proxy_fcgi Apache non lo inoltra
    # di default, quindi upload.php non vedeva il Bearer token. auth.php lo legge poi da
    # REDIRECT_HTTP_AUTHORIZATION. Senza questa riga ogni upload autenticato falliva con "token mancante".
    RewriteCond %{HTTP:Authorization} .+
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    # Risposta 204 alle preflight OPTIONS
    RewriteCond %{REQUEST_METHOD} =OPTIONS
    RewriteRule ^ - [R=204,L]
</IfModule>

# --- CORS ---
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "POST, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Authorization, Content-Type"
</IfModule>

# --- Cache immagini ---
<FilesMatch "\.(jpg|jpeg|png|webp|gif)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=31536000"
    </IfModule>
</FilesMatch>
