# POILOVE presentazione - no aggressive cache + kill old PWA service workers

# Default: HTML content always revalidated
<FilesMatch "\.(html|json)$">
  Header set Cache-Control "no-cache, must-revalidate"
  Header unset ETag
  FileETag None
</FilesMatch>

# Asset statici (PDF, txt notarizzazione): cache breve 1h
<FilesMatch "\.(pdf|txt|svg|png|jpg|jpeg|gif|webp)$">
  Header set Cache-Control "public, max-age=3600"
</FilesMatch>

# Disabilita range serving del service worker della vecchia webapp
<FilesMatch "service-worker\.js$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>
